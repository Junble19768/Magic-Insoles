[Unit]
Description=magic-insoles FastAPI backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/magic-insoles/backend
Environment=PATH=/var/www/magic-insoles/venv/bin
ExecStart=/var/www/magic-insoles/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
